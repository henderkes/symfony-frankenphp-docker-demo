{% extends 'base.html.twig' %}

{% block body_id 'blog_index' %}

{% block main %}
    <div class="mb-3">
        <a href="{{ path('blog_index') }}" class="btn btn-sm btn-outline-primary">Back to blog</a>
        <a href="{{ path('blog_all') }}" class="btn btn-sm btn-outline-primary">Fork (single)</a>
        <a href="{{ path('blog_all_fork', {num: 9}) }}" class="btn btn-sm btn-outline-primary">Fork/9</a>
        <a href="{{ path('blog_ext_parallel') }}" class="btn btn-sm btn-outline-secondary">ext-parallel (single)</a>
        <a href="{{ path('blog_ext_parallel_num', {num: 9}) }}" class="btn btn-sm btn-outline-secondary">ext-parallel/9</a>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <nav>
            <ul class="pagination justify-content-center mb-0" id="pagination">
            </ul>
        </nav>
        <small class="text-muted text-nowrap ms-3">
            {{ numResults }} posts &middot; {{ totalPages }} pages &middot; {{ elapsed_ms }} ms ({{ mode }})
        </small>
    </div>

    {% if timings is defined and timings|length > 0 %}
        <details class="mb-3">
            <summary class="small text-muted" style="cursor:pointer">fork timing breakdown ({{ timings|length }} workers, total {{ elapsed_ms }} ms)</summary>
            <div class="mt-2">
                <table class="table table-sm table-bordered small mb-2" style="font-family:monospace">
                    <thead>
                        <tr>
                            <th>worker</th>
                            <th class="text-end">pages</th>
                            <th class="text-end">spawn&nbsp;ms</th>
                            <th class="text-end">spawned@</th>
                            <th class="text-end">child&nbsp;start@</th>
                            <th class="text-end">child&nbsp;end@</th>
                            <th class="text-end">compute&nbsp;ms</th>
                            <th class="text-end">reap&nbsp;wait&nbsp;ms</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for i, t in timings %}
                            {% set compute = (t.end_ms|default(0)) - (t.start_ms|default(0)) %}
                            {% set reap = (t.reap_end_ms|default(0)) - (t.reap_start_ms|default(0)) %}
                            <tr>
                                <td>{{ i == 0 ? '0 (main)' : i }}</td>
                                <td class="text-end">{{ t.pages }}</td>
                                <td class="text-end">{{ t.spawn_ms }}</td>
                                <td class="text-end">{{ t.spawned_at_ms }}</td>
                                <td class="text-end">{{ t.start_ms|default('—') }}</td>
                                <td class="text-end">{{ t.end_ms|default('—') }}</td>
                                <td class="text-end">{{ compute|round(2) }}</td>
                                <td class="text-end">{{ reap|round(2) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>

                <div style="position:relative; height:{{ (timings|length * 18) + 4 }}px; background:#f5f5f5; border:1px solid #ddd; font-family:monospace; font-size:10px">
                    {% for i, t in timings %}
                        {% set spawn_pct  = t.spawned_at_ms                / elapsed_ms * 100 %}
                        {% set start_pct  = (t.start_ms|default(0))        / elapsed_ms * 100 %}
                        {% set end_pct    = (t.end_ms|default(0))          / elapsed_ms * 100 %}
                        {% set reap_s_pct = (t.reap_start_ms|default(0))   / elapsed_ms * 100 %}
                        {% set reap_e_pct = (t.reap_end_ms|default(0))     / elapsed_ms * 100 %}
                        <div style="position:absolute; top:{{ i * 18 + 2 }}px; left:0; width:100%; height:16px">
                            {# fork+handshake latency: from spawn moment to child-compute start #}
                            <div title="fork+handshake" style="position:absolute; top:0; left:{{ spawn_pct }}%; width:{{ (start_pct - spawn_pct)|abs }}%; height:100%; background:#d4b000"></div>
                            {# child compute #}
                            <div title="child compute" style="position:absolute; top:0; left:{{ start_pct }}%; width:{{ (end_pct - start_pct) }}%; height:100%; background:#3a84d6"></div>
                            {# parent reap wait (idle, waiting for this child's payload to arrive) #}
                            <div title="reap wait" style="position:absolute; top:0; left:{{ reap_s_pct }}%; width:{{ (reap_e_pct - reap_s_pct) }}%; height:100%; background:#b33a3a; opacity:0.6"></div>
                            <div style="position:absolute; top:1px; left:4px; color:#000; font-weight:bold">{{ i == 0 ? 'main' : i }}</div>
                        </div>
                    {% endfor %}
                </div>
                <div class="small text-muted mt-1">
                    <span style="background:#d4b000">&nbsp;&nbsp;&nbsp;</span> fork+handshake
                    &nbsp;<span style="background:#3a84d6">&nbsp;&nbsp;&nbsp;</span> child compute
                    &nbsp;<span style="background:#b33a3a;opacity:0.6">&nbsp;&nbsp;&nbsp;</span> parent reap wait
                </div>
            </div>
        </details>
    {% endif %}

    {% for page, html in pages %}
        <div class="page-content" id="page-{{ page }}" style="{{ page != currentPage ? 'display: none;' }}">
            {{ html|raw }}
        </div>
    {% endfor %}

    <script>
        (function() {
            var totalPages = {{ totalPages }};
            var currentPage = {{ currentPage }};
            var pagination = document.getElementById('pagination');
            var maxVisible = 7;

            function goToPage(page) {
                document.querySelectorAll('.page-content').forEach(function(el) {
                    el.style.display = 'none';
                });
                var target = document.getElementById('page-' + page);
                if (target) target.style.display = 'block';
                currentPage = page;
                renderPagination();
                window.scrollTo({top: 0, behavior: 'smooth'});
            }

            function renderPagination() {
                var html = '';

                // Previous
                html += '<li class="page-item ' + (currentPage <= 1 ? 'disabled' : '') + '">';
                html += '<a class="page-link" href="#" data-page="' + (currentPage - 1) + '">&laquo;</a></li>';

                // First page
                html += pageItem(1);

                if (totalPages <= maxVisible + 2) {
                    for (let i = 2; i < totalPages; i++) html += pageItem(i);
                } else {
                    var start = Math.max(2, currentPage - Math.floor(maxVisible / 2));
                    var end = Math.min(totalPages - 1, start + maxVisible - 1);
                    start = Math.max(2, end - maxVisible + 1);

                    if (start > 2) html += '<li class="page-item disabled"><span class="page-link">&hellip;</span></li>';
                    for (let i = start; i <= end; i++) html += pageItem(i);
                    if (end < totalPages - 1) html += '<li class="page-item disabled"><span class="page-link">&hellip;</span></li>';
                }

                // Last page
                if (totalPages > 1) html += pageItem(totalPages);

                // Next
                html += '<li class="page-item ' + (currentPage >= totalPages ? 'disabled' : '') + '">';
                html += '<a class="page-link" href="#" data-page="' + (currentPage + 1) + '">&raquo;</a></li>';

                pagination.innerHTML = html;

                pagination.querySelectorAll('a.page-link').forEach(function(a) {
                    a.addEventListener('click', function(e) {
                        e.preventDefault();
                        var p = parseInt(this.getAttribute('data-page'));
                        if (p >= 1 && p <= totalPages) goToPage(p);
                    });
                });
            }

            function pageItem(i) {
                if (i === currentPage) {
                    return '<li class="page-item active"><span class="page-link">' + i + '</span></li>';
                }
                return '<li class="page-item"><a class="page-link" href="#" data-page="' + i + '">' + i + '</a></li>';
            }

            renderPagination();
        })();
    </script>
{% endblock %}

{% block sidebar %}
    {{ parent() }}

    {{ show_source_code(_self) }}
    {{ include('blog/_rss.html.twig') }}
{% endblock %}
